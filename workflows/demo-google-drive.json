{"name":"Demo Google Drive - lacasademo","nodes":[{"parameters":{},"name":"Ejecutar Manual","type":"n8n-nodes-base.manualTrigger","typeVersion":1,"position":[250,300]},{"parameters":{"operation":"search","queryString":"mimeType='application/pdf'","limit":100,"options":{"driveId":{"__rl":true,"mode":"list","value":"MyDrive"}}},"name":"1. Buscar PDFs en Drive","type":"n8n-nodes-base.googleDrive","typeVersion":3,"position":[480,300]},{"parameters":{"jsCode":"// Filtrar solo PDFs de la carpeta lacasademo\nconst items = $input.all();\nconst pdfs = items.filter(item => {\n  const name = item.json.name || '';\n  return name.toLowerCase().endsWith('.pdf');\n});\n\nreturn [{ json: { totalPdfs: pdfs.length, pdfs: pdfs.map(p => ({ name: p.json.name, id: p.json.id, webViewLink: p.json.webViewLink })) } }];"},"name":"2. Parsear resultados","type":"n8n-nodes-base.code","typeVersion":2,"position":[700,300]},{"parameters":{"values":{"string":[{"name":"status","value":"Deploy OK - Google Drive funciona"}]},"options":{}},"name":"3. Output","type":"n8n-nodes-base.set","typeVersion":3.4,"position":[920,300]}],"connections":{"Ejecutar Manual":{"main":[[{"node":"1. Buscar PDFs en Drive","type":"main","index":0}]]},"1. Buscar PDFs en Drive":{"main":[[{"node":"2. Parsear resultados","type":"main","index":0}]]},"2. Parsear resultados":{"main":[[{"node":"3. Output","type":"main","index":0}]]}},"settings":{"executionOrder":"v1"},"active":false}